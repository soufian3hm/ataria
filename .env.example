# Password for /admin dashboard
ADMIN_PASSWORD=fadak123
# Any random string, used to sign the admin session cookie
AUTH_SECRET=change-me

# Supabase — the app stores all content in a single `linkhub` table.
# When these are missing it falls back to file storage (data/store.json).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
